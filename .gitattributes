# Normalise line endings: LF in the repository, native in the working tree.
* text=auto eol=lf

*.py     text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.json   text eol=lf
*.toml   text eol=lf
*.txt    text eol=lf
*.html   text eol=lf
*.cfg    text eol=lf

*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.svg    text eol=lf
